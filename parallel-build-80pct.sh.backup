#!/bin/bash
set -euo pipefail

# Configuration
MAX_LOAD=12.8          # 80% of 16 cores (16 * 0.8)
CHECK_INTERVAL=5       # seconds
LOG_DIR="/root/.openclaw/workspace/build-logs"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BUILD_LOG="$LOG_DIR/build-$TIMESTAMP.log"
SUMMARY_LOG="$LOG_DIR/summary-$TIMESTAMP.json"
PID_DIR="/tmp/build_pids_$$"
mkdir -p "$LOG_DIR"
mkdir -p "$PID_DIR"

# Arrays to track tasks
declare -A TASK_PIDS
declare -A TASK_NAMES
declare -A TASK_COMMANDS
declare -A TASK_START
declare -A TASK_EXIT
declare -A TASK_LOGS

# Function to log
log() {
    echo "[$(date +%Y-%m-%d\ %H:%M:%S)] $*" | tee -a "$BUILD_LOG"
}

# Function to get current load average (1‑minute)
get_load() {
    awk '{print $1}' /proc/loadavg
}

# Function to throttle if load too high
throttle_check() {
    local load=$(get_load)
    if (( $(echo "$load > $MAX_LOAD" | bc -l) )); then
        log "WARNING: Load $load > $MAX_LOAD, throttling all tasks"
        for pid in "${!TASK_PIDS[@]}"; do
            kill -STOP "$pid" 2>/dev/null && log "Stopped PID $pid"
        done
        return 1
    else
        # Ensure all tasks are running
        for pid in "${!TASK_PIDS[@]}"; do
            kill -CONT "$pid" 2>/dev/null
        done
        return 0
    fi
}

# Function to start a task
start_task() {
    local name="$1"
    local cmd="$2"
    local logfile="$LOG_DIR/${name}-$TIMESTAMP.log"
    TASK_LOGS[$name]="$logfile"
    TASK_START[$name]=$(date +%s)
    log "Starting $name: $cmd"
    # Use cpulimit to limit each task to 20% CPU? Not needed if we throttle globally.
    # Run with nice and taskset to spread across cores 0-15.
    taskset -c 0-15 nice -n 10 bash -c "$cmd" >> "$logfile" 2>&1 &
    local pid=$!
    TASK_PIDS[$pid]="$name"
    TASK_NAMES[$name]="$pid"
    TASK_COMMANDS[$name]="$cmd"
    echo "$pid" > "$PID_DIR/$name.pid"
    log "  -> PID $pid"
}

# Function to monitor tasks
monitor_tasks() {
    local all_done=0
    while [[ $all_done -eq 0 ]]; do
        sleep "$CHECK_INTERVAL"
        throttle_check
        all_done=1
        for pid in "${!TASK_PIDS[@]}"; do
            if kill -0 "$pid" 2>/dev/null; then
                all_done=0
            else
                # Process finished, wait to collect exit code
                wait "$pid" 2>/dev/null
                local exit_code=$?
                local name="${TASK_PIDS[$pid]}"
                if [[ -z "$name" ]]; then continue; fi
                TASK_EXIT[$name]=$exit_code
                log "Task $name finished with exit $exit_code"
                unset TASK_PIDS[$pid]
                # Remove pid file
                rm -f "$PID_DIR/$name.pid"
            fi
        done
    done
}

# Function to generate summary
generate_summary() {
    local end_time=$(date +%s)
    local summary="{"
    summary+="\"timestamp\":\"$TIMESTAMP\","
    summary+="\"max_load\":$MAX_LOAD,"
    summary+="\"tasks\":["
    local first=true
    for name in "${!TASK_COMMANDS[@]}"; do
        if [[ "$first" != true ]]; then
            summary+=","
        fi
        first=false
        local start=${TASK_START[$name]}
        local end=$end_time
        local duration=$((end - start))
        local exit_code=${TASK_EXIT[$name]:--1}
        summary+="{\"name\":\"$name\",\"start\":$start,\"duration\":$duration,\"exit\":$exit_code,\"log\":\"${TASK_LOGS[$name]}\"}"
    done
    summary+="]}"
    echo "$summary" > "$SUMMARY_LOG"
    log "Summary written to $SUMMARY_LOG"
    # Pretty print
    python3 -m json.tool "$SUMMARY_LOG" 2>/dev/null || cat "$SUMMARY_LOG"
}

# Main
log "=== Parallel Build Orchestrator (CPU cap 80%) ==="
log "Log directory: $LOG_DIR"
log "Max load: $MAX_LOAD"

# Start BitNet (llama.cpp) compilation
cd /root/.openclaw/workspace/bitnet/3rdparty/llama.cpp
start_task "bitnet" "make -j12"

# Start Truthfully TypeScript build
cd /root/.openclaw/workspace/truthfully
start_task "truthfully-build" "npm run build:all"

# Start Truthfully test suite
cd /root/.openclaw/workspace/truthfully
start_task "truthfully-test" "npm run test"

# Start Deception Floor Factory tests (optional)
cd /root/.openclaw/workspace/deception-floor-commodity-factory
if [[ -f package.json ]]; then
    start_task "deception-floor-test" "npm test"
else
    log "Skipping deception-floor-test (package.json not found)"
fi

# Start monitoring
log "Monitoring tasks..."
monitor_tasks

log "All tasks completed."
generate_summary

# Cleanup
rm -rf "$PID_DIR"
log "Done."