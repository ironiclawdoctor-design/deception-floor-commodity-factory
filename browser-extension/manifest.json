{
  "manifest_version": 3,
  "name": "OpenClaw Browser Relay (Agency)",
  "version": "1.0.0",
  "description": "Private browser extension for OpenClaw agency session management",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://console.cloud.google.com/*",
    "https://accounts.google.com/*",
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OpenClaw Agency",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://console.cloud.google.com/*"],
      "js": ["content/google-cloud.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject/*"],
      "matches": ["<all_urls>"]
    }
  ]
}